# Copy this file to ".env" in the same folder as main.py and fill in your keys.
# .env is gitignored.

# Option A: JWT from a logged-in session (same as the web app's Authorization header).
WUT8_JWT=
# Option B: Postgres URL — or omit both and use the URL in api/test_recent_posts.js in this repo.
# WUT8_DATABASE_URL=postgres://...
# DATABASE_URL=...

# Optional: API origin (default http://localhost:3001) — only needed for JWT comment fetch / discovery.
# WUT8_API_URL=https://your-api.example.com
# Link shown in the video header (default https://8wut.org)
# WUT8_APP_URL=https://8wut.org

OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini

# xAI Grok Imagine video backgrounds (python main.py --fetch-grok-bgs)
# GROK_KEY=...
# XAI_API_KEY=...   # alternative name
# Grok backgrounds: default export cycles grok_bg_01.mp4 … grok_bg_07.mp4 (video-only after fetch).
# Loop only the first file:
# WUT8_GROK_SINGLE_BG=1
# Seconds per segment when cycling multiple Grok clips:
# WUT8_GROK_BG_SEGMENT_SEC=4
# Strip audio from existing clips: python main.py --strip-grok-bg-audio

# Optional: looping video background (MP4/WebM/MOV) e.g. vertical Minecraft gameplay.
# Default: Grok clips in data/grok_bg_clips/ take priority when those files exist.
# Set to 1/true/yes/on to use WUT8_BG_VIDEO *before* Grok when both are available:
# WUT8_BG_VIDEO_FIRST=1
# WUT8_BG_VIDEO=C:\path\to\minecraft_loop.mp4
# If unset and no Grok clips, uses minecraft_bg.mp4 next to main.py when that file exists, else stars.

# Optional: YouTube search for: python main.py --fetch-minecraft-bg
# WUT8_PARKOUR_QUERY=minecraft parkour tiktok format

# Optional: truncate custom tone file (eightwut_video_maker/data/prompt_tone.txt)
# WUT8_INSPIRATION_MAX_CHARS=8000

# Optional: folder of GIFs used as drifting sprites (see --floater-keys-dir)
# WUT8_FLOATER_KEYS_DIR=C:\path\to\key_gifs
